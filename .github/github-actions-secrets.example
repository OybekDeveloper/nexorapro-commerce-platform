# GitHub → Settings → Environments → production → Environment secrets
# This is a names-only template. Never put real credentials in this committed file.

VPS_HOST=YOUR_VPS_IP
VPS_PORT=22
VPS_USER=YOUR_DEPLOY_USER
VPS_SSH_PRIVATE_KEY=PASTE_THE_COMPLETE_PRIVATE_KEY_IN_GITHUB_ONLY
VPS_KNOWN_HOSTS=PASTE_THE_VERIFIED_SSH_HOST_KEY_LINE
NEXT_PUBLIC_APP_URL=https://nexorapro.uz
PRODUCTION_ENV_FILE=COPY_THE_FILLED_MULTILINE_PRODUCTION_ENV_TEMPLATE
