# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Yandex is used only for the visual map and point selection.
NEXT_PUBLIC_YANDEX_MAPS_JS_API_KEY=
# OpenStreetMap Nominatim is used for address/name search and reverse geocoding.
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org

# Local persistent database (optional; defaults to data/nexora.db)
NEXORAPRO_DB_PATH=./data/nexora.db
DB_MIGRATION_BACKUP_DIR=./data/migration-backups
# Product uploads (production should point to the shared release-independent directory)
UPLOAD_DIR=/absolute/path/to/nexorapro-uploads

# Production authentication (required before first production start)
ADMIN_NAME=Oybek
ADMIN_EMAIL=admin@nexorapro.uz
ADMIN_PASSWORD=replace-with-a-strong-unique-password
SESSION_TTL_DAYS=7

# Production object storage (next phase)
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
