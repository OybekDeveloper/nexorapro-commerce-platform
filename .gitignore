# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.playwright-cli/
/output/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Local-only VPS credentials and deployment access
.server-access

# local persistent database
data/*.db
data/*.db-*
data/*.sqlite
data/*.sqlite-*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
